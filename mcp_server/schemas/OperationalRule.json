{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "OperationalRule",
  "title": "OperationalRule",
  "description": "A self-audit rule or operational constraint",
  "type": "object",
  "required": [
    "subject",
    "predicate",
    "value"
  ],
  "properties": {
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "predicate": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "value": {
      "description": "Bounded JSON value: primitive, array, or object with capped string length, item counts, property counts, and nesting depth.",
      "allOf": [
        {
          "$ref": "#/definitions/boundedValue"
        }
      ]
    },
    "enforcement": {
      "type": "string",
      "enum": [
        "hard",
        "soft",
        "advisory"
      ],
      "default": "soft"
    },
    "applies_to": {
      "type": "string",
      "description": "Scope of agents or roles this rule applies to",
      "maxLength": 512
    }
  },
  "additionalProperties": false,
  "definitions": {
    "boundedString": {
      "type": "string",
      "maxLength": 8192
    },
    "boundedPrimitive": {
      "anyOf": [
        {
          "$ref": "#/definitions/boundedString"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "boundedArrayLevel1": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/definitions/boundedPrimitive"
      }
    },
    "boundedObjectLevel1": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "additionalProperties": {
        "$ref": "#/definitions/boundedPrimitive"
      }
    },
    "boundedValueLevel1": {
      "anyOf": [
        {
          "$ref": "#/definitions/boundedPrimitive"
        },
        {
          "$ref": "#/definitions/boundedArrayLevel1"
        },
        {
          "$ref": "#/definitions/boundedObjectLevel1"
        }
      ]
    },
    "boundedArrayLevel2": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/definitions/boundedValueLevel1"
      }
    },
    "boundedObjectLevel2": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "additionalProperties": {
        "$ref": "#/definitions/boundedValueLevel1"
      }
    },
    "boundedValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/boundedPrimitive"
        },
        {
          "$ref": "#/definitions/boundedArrayLevel2"
        },
        {
          "$ref": "#/definitions/boundedObjectLevel2"
        }
      ]
    }
  }
}
