{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "Candidate",
  "title": "Candidate",
  "description": "A persisted candidate row in the quarantine/promotion workflow",
  "type": "object",
  "required": [
    "uuid",
    "type",
    "subject",
    "predicate",
    "value",
    "status",
    "confidence",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "uuid": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this candidate",
      "maxLength": 256,
      "pattern": "^[a-z0-9][a-z0-9:_-]{0,255}$"
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Candidate assertion type for this row (for example preference, commitment, operational_rule, procedure, episode)."
    },
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "predicate": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "value": {
      "description": "Bounded JSON value: primitive, array, or object with capped string length, item counts, property counts, and nesting depth.",
      "allOf": [
        {
          "$ref": "#/definitions/boundedValue"
        }
      ]
    },
    "conflicting_fact_uuid": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "status": {
      "type": "string",
      "enum": [
        "quarantine",
        "promoted",
        "rejected"
      ],
      "default": "quarantine"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reviewed_by": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "promoted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "promoted_by": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "reason": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2048
    },
    "resolution": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "supersede",
        "parallel",
        "cancel",
        null
      ],
      "description": "Conflict-resolution decision attached to a candidate outcome."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ],
      "maxProperties": 128
    }
  },
  "additionalProperties": false,
  "definitions": {
    "boundedString": {
      "type": "string",
      "maxLength": 8192
    },
    "boundedPrimitive": {
      "anyOf": [
        {
          "$ref": "#/definitions/boundedString"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "boundedArrayLevel1": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/definitions/boundedPrimitive"
      }
    },
    "boundedObjectLevel1": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "additionalProperties": {
        "$ref": "#/definitions/boundedPrimitive"
      }
    },
    "boundedValueLevel1": {
      "anyOf": [
        {
          "$ref": "#/definitions/boundedPrimitive"
        },
        {
          "$ref": "#/definitions/boundedArrayLevel1"
        },
        {
          "$ref": "#/definitions/boundedObjectLevel1"
        }
      ]
    },
    "boundedArrayLevel2": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/definitions/boundedValueLevel1"
      }
    },
    "boundedObjectLevel2": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "additionalProperties": {
        "$ref": "#/definitions/boundedValueLevel1"
      }
    },
    "boundedValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/boundedPrimitive"
        },
        {
          "$ref": "#/definitions/boundedArrayLevel2"
        },
        {
          "$ref": "#/definitions/boundedObjectLevel2"
        }
      ]
    }
  }
}
