{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "PackDefinition",
  "title": "PackDefinition",
  "description": "Detailed pack descriptor returned by describe_pack",
  "type": "object",
  "required": [
    "pack_id",
    "pack_registry",
    "predicates",
    "schema",
    "examples",
    "definition"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "pack_registry": {
      "type": "object",
      "required": [
        "id",
        "scope",
        "intent",
        "description",
        "consumer",
        "version",
        "predicates",
        "created_at",
        "last_updated"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
        },
        "scope": {
          "type": "string",
          "enum": [
            "context",
            "workflow"
          ]
        },
        "intent": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8192
        },
        "consumer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "version": {
          "type": "string",
          "pattern": "^(\\d+)\\.(\\d+)\\.(\\d+)$"
        },
        "predicates": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "predicates": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "schema": {
      "type": "object"
    },
    "examples": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": [
          "object",
          "array",
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    },
    "instructions": {
      "type": [
        "string",
        "null"
      ]
    },
    "definition": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "step",
              "action"
            ],
            "properties": {
              "step": {
                "type": "string",
                "minLength": 1,
                "maxLength": 2048
              },
              "action": {
                "type": "string",
                "minLength": 1,
                "maxLength": 2048
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "pack_registry": {
            "properties": {
              "scope": {
                "const": "workflow"
              }
            },
            "required": [
              "scope"
            ]
          }
        },
        "required": [
          "pack_registry"
        ]
      },
      "then": {
        "properties": {
          "definition": {
            "required": [
              "steps"
            ]
          }
        }
      }
    }
  ]
}
