{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "PackDefinition",
  "title": "PackDefinition",
  "description": "Full pack schema including registry metadata and rules",
  "type": "object",
  "required": [
    "pack_id",
    "scope",
    "intent",
    "consumer",
    "version"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9_-]+$"
    },
    "scope": {
      "type": "string",
      "enum": [
        "context",
        "workflow",
        "both"
      ]
    },
    "intent": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "consumer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$",
      "default": "1.0"
    },
    "context_rules": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048
      },
      "description": "Rules for what facts to include as context"
    },
    "workflow_steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048
      },
      "description": "Ordered steps for the workflow"
    },
    "prerequisites": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[a-z0-9_-]+$"
      },
      "description": "Other pack IDs that must be loaded first"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "const": "context"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "context_rules"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "workflow"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "workflow_steps"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "both"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "context_rules",
          "workflow_steps"
        ]
      }
    }
  ]
}
