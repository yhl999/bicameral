{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "PackRegistry",
  "title": "PackRegistry",
  "description": "Pack metadata entry returned by list_packs/create_workflow_pack/describe_pack.pack_registry",
  "type": "object",
  "required": [
    "id",
    "scope",
    "intent",
    "description",
    "consumer",
    "version",
    "predicates",
    "created_at",
    "last_updated"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "scope": {
      "type": "string",
      "enum": [
        "context",
        "workflow"
      ]
    },
    "intent": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192
    },
    "consumer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "pattern": "^(\\d+)\\.(\\d+)\\.(\\d+)$"
    },
    "predicates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
