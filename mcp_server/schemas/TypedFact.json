{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "TypedFact",
  "title": "TypedFact",
  "description": "A typed, temporally-versioned fact in the memory ledger",
  "type": "object",
  "required": [
    "subject",
    "predicate",
    "value",
    "fact_type"
  ],
  "properties": {
    "subject": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "The entity this fact is about"
    },
    "predicate": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "The relationship or attribute name"
    },
    "value": {
      "description": "The fact value (string, number, boolean, or object)"
    },
    "fact_type": {
      "type": "string",
      "enum": [
        "preference",
        "decision",
        "commitment",
        "lesson",
        "world_state",
        "operational_rule",
        "constraint",
        "relationship"
      ],
      "description": "The semantic category of this fact"
    },
    "scope": {
      "type": "string",
      "default": "private",
      "description": "Visibility scope of this fact"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp when this fact was recorded"
    }
  },
  "additionalProperties": true,
  "examples": [
    {
      "subject": "user",
      "predicate": "prefers_dark_mode",
      "value": true,
      "fact_type": "preference",
      "scope": "private"
    }
  ]
}